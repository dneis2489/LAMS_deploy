COMPOSE_PROJECT_NAME=lams
HTTP_PORT=80

POSTGRES_PASSWORD=replace-with-strong-postgres-password
SECURITY_JWT_SECRET=replace-with-at-least-32-byte-random-secret

# Ollama is not deployed in this project.
LAMS_AI_SMART_SEARCH_ENABLED=false
LAMS_AI_API_KEY=

# Empty value means same-origin API calls through nginx: /lams -> backend.
FRONTEND_API_BASE_URL=

GENERATOR_MODE=continuous
GENERATOR_INTERVAL_MS=1000
GENERATOR_BURST_SIZE=1
