# Copy to .env for local Docker Compose runs and replace placeholder values.
POSTGRES_PASSWORD=replace-with-local-postgres-password
SECURITY_JWT_SECRET=replace-with-at-least-32-byte-random-secret

# Optional: enable only when an OpenAI-compatible local endpoint is ready.
LAMS_AI_SMART_SEARCH_ENABLED=false
LAMS_AI_API_KEY=
